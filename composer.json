{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/standard-lifecycle",
    "description": "Composer plugins and tools to manage the installation, update, and lifecycle of Webkernel modules.",
    "version": "0.1.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "composer-plugin",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/standard-installer/issues"
    },
    "require": {
        "composer/composer": "^2.0",
        "composer/installers": "^2.0",
        "composer-plugin-api": "^2.0",
        "laravel/framework": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^7.2",
        "squizlabs/php_codesniffer": "^3.3"
    },
    "autoload": {
        "files": [],
        "classmap": [],
        "psr-4": {
            "Webkernel\\StdLifecycle\\": "src/"
        }
    },
    "scripts": {
        "fix": "vendor/bin/phpcbf",
        "lint": "vendor/bin/phpcs",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "class": "Webkernel\\StdLifecycle\\Installer",
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/standard-installer.git",
            "prefix": "standard"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
